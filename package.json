{
  "name": "badge-sync",
  "version": "0.1.1",
  "description": "Keep your README badges clean, valid, and consistent",
  "type": "module",
  "bin": {
    "badge-sync": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "test:e2e": "./scripts/e2e-repos.sh",
    "test:e2e:quick": "./scripts/e2e-repos.sh --quick",
    "prepare": "husky"
  },
  "keywords": [
    "badge",
    "readme",
    "shields",
    "cli",
    "markdown",
    "github-actions",
    "ci",
    "npm",
    "pypi",
    "crates-io",
    "monorepo"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yeongseon/badge-sync.git"
  },
  "homepage": "https://github.com/yeongseon/badge-sync#readme",
  "bugs": {
    "url": "https://github.com/yeongseon/badge-sync/issues"
  },
  "author": "yeongseon",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "fast-glob": "^3.3.2",
    "yaml": "^2.5.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@vitest/coverage-v8": "^2.1.0",
    "husky": "^9.1.7",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  }
}
