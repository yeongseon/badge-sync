{
  "name": "badge-sync",
  "version": "0.1.0",
  "description": "Keep your README badges clean, valid, and consistent",
  "type": "module",
  "bin": {
    "badge-sync": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "test:e2e": "./scripts/e2e-repos.sh",
    "test:e2e:quick": "./scripts/e2e-repos.sh --quick"
  },
  "keywords": [
    "badge",
    "readme",
    "shields",
    "cli",
    "markdown"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "fast-glob": "^3.3.2",
    "yaml": "^2.5.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@vitest/coverage-v8": "^2.1.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  }
}
